<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".Question5">

    <TextView
        android:id="@+id/textViewQuestion5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:layout_marginBottom="30dp"
        android:gravity="center"
        android:text="Who is known as the Father of the Nation (India)?"
        android:textSize="24sp"
        android:textStyle="bold|italic" />

    <RadioGroup
        android:id="@+id/rg5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:paddingStart="40dp">

        <RadioButton
            android:id="@+id/rb5_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subhash Chandra Bose"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/rb5_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jawaharlal Nehru"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/rb5_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mahatma Gandhi"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/rb5_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sardar Patel"
            android:textSize="18sp" />
    </RadioGroup>

    <Button
        android:id="@+id/button55"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="Finish Quiz"
        android:textStyle="bold|italic" />

</LinearLayout>
