<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050A11"
    tools:context=".Splash">

    <!-- Background Glow Effect (Enhanced depth) -->
    <View
        android:id="@+id/glowEffect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/radial_glow"
        android:alpha="0.8" />

    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:src="@drawable/logo"
            android:scaleType="centerInside"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="OmniHub"
            android:textColor="#E0F7FA"
            android:textSize="54sp"
            android:letterSpacing="0.03"
            android:textStyle="bold"
            android:shadowColor="#8000E5FF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="15" />

        <TextView
            android:id="@+id/splashSubTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="All-in-One Utility Companion"
            android:textColor="#90A4AE"
            android:textSize="18sp"
            android:letterSpacing="0.15"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- Progress Container at the bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="60dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Loading... 0%"
            android:textColor="#00E5FF"
            android:textSize="16sp"
            android:textStyle="bold|italic" />

        <ProgressBar
            android:id="@+id/splashProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="280dp"
            android:layout_height="10dp"
            android:max="100"
            android:progressDrawable="@drawable/custom_progress_bar" />

    </LinearLayout>

</RelativeLayout>
